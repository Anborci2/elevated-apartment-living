# -------------------------------------------------------
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to GitHub.
# -------------------------------------------------------

# RESEND — email delivery for contact form leads
# Get this from resend.com > API Keys
RESEND_API_KEY=re_REPLACE_WITH_ALAN_API_KEY

# The email address where leads should be delivered
LEAD_EMAIL=alan@elevatedapartmentlocating.com

# SANITY — CMS for reviews and content management
# Get this from sanity.io > your project dashboard
NEXT_PUBLIC_SANITY_PROJECT_ID=REPLACE_WITH_SANITY_PROJECT_ID
NEXT_PUBLIC_SANITY_DATASET=production

# GOOGLE PLACES — nightly review sync
# Get API key from console.cloud.google.com
# Get Place ID from Google Business Profile
GOOGLE_PLACES_API_KEY=REPLACE_WITH_GOOGLE_API_KEY
GOOGLE_PLACE_ID=REPLACE_WITH_GOOGLE_PLACE_ID

# GOOGLE ANALYTICS — site traffic tracking
# Get this from analytics.google.com > Admin > Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-REPLACE_WITH_GA_ID
